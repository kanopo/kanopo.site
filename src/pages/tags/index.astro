---
import Layout from "../../layouts/Layout.astro";
const allWikiPosts = await Astro.glob("../wiki/*.md");
const nonDraftPosts = allWikiPosts.filter((post) => !post.frontmatter.draft);
const tags = [
  ...new Set(nonDraftPosts.map((post) => post.frontmatter.tags).flat()),
];
const pageTitle = "Tag Index";
---

<Layout title={pageTitle}>
  <div>
    {
      tags.map((tag) => (
        <ul class="tag">
          <li>
            <a href={`/tags/${tag}`}>{tag}</a>
          </li>
        </ul>
      ))
    }
  </div>
</Layout>
